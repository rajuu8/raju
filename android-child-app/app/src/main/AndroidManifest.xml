<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground service (required to run background tasks transparently, shows persistent notification) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- Internet -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- App usage stats (user must grant via Settings > Usage Access screen) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Detect new app installs -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- Call log (metadata only - numbers & duration, NOT recording calls) -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- Battery status -->
    <uses-permission android:name="android.permission.BATTERY_STATS" tools:ignore="ProtectedPermissions" />

    <!-- Boot receiver so monitoring restarts after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_shield"
        android:label="Family Safety"
        android:theme="@style/Theme.ParentalControlChild">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.SosActivity" android:exported="false" />

        <!-- Foreground service: location + heartbeat + usage sync (ALWAYS shows a notification, by design) -->
        <service
            android:name=".services.MonitoringService"
            android:foregroundServiceType="location"
            android:exported="false" />

        <!-- Screen mirroring service - only active when parent requests AND child has approved.
             Android shows a mandatory system notification + indicator whenever this runs. -->
        <service
            android:name=".services.ScreenCaptureService"
            android:foregroundServiceType="mediaProjection"
            android:exported="false" />

        <receiver
            android:name=".receivers.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receivers.AppInstallReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
